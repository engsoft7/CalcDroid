# Copie este arquivo para keystore.properties (na raiz do projeto) e preencha
# com as credenciais reais do seu keystore de upload.
# NUNCA faça commit do keystore.properties nem do arquivo .jks - ambos ja
# estao no .gitignore.
#
# Para gerar um keystore novo:
#   keytool -genkeypair -v -keystore calcdroid-upload.jks -keyalg RSA \
#     -keysize 2048 -validity 10000 -alias calcdroid-upload
storeFile=calcdroid-upload.jks
storePassword=SUA_SENHA_DO_KEYSTORE
keyAlias=calcdroid-upload
keyPassword=SUA_SENHA_DA_CHAVE
